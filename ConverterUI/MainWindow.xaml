<Window x:Class="ConverterUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FFmpeg Converter" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- For buttons/controls -->
            <RowDefinition Height="*"/>    <!-- For OutputBox -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10">
            <TextBlock Text="Select GPU Vendor:" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton x:Name="NvidiaRadio" Content="Nvidia" IsChecked="True" Margin="0,0,10,0"/>
                <RadioButton x:Name="IntelRadio" Content="Intel"/>
            </StackPanel>
            <Button x:Name="SelectFilesButton" Content="Select Video Files..." Width="150" Click="SelectFilesButton_Click"/>
            <ListBox x:Name="FilesList" Height="80" Margin="0,10,0,10"/>
            <Button x:Name="ConvertButton" Content="Convert" Width="100" Click="ConvertButton_Click" IsEnabled="False"/>
        </StackPanel>

        <TextBox x:Name="OutputBox"
                 Grid.Row="1"
                 Margin="5"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalAlignment="Stretch"
                 HorizontalAlignment="Stretch"/>
    </Grid>
</Window>